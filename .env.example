# ================================================
# 成本管理系统 - 环境变量示例
# 复制此文件为 .env 并修改配置
# ================================================

# ------------------------------------------------
# 必需配置
# ------------------------------------------------

# JWT 密钥（生产环境请使用强密码）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 数据库连接（PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cost_management

# ------------------------------------------------
# 前端配置
# ------------------------------------------------

# API 基础 URL（服务端渲染时使用）
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1

# ------------------------------------------------
# 后端配置
# ------------------------------------------------

# 服务端口
PORT=3003
HOST=0.0.0.0

# CORS 配置（前端地址）
CORS_ORIGIN=http://localhost:3002

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 日志级别（debug | info | warn | error）
LOG_LEVEL=info

# Redis 配置
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=cost:api:

# 缓存 TTL 配置（秒）
REDIS_TTL_DASHBOARD=300      # 仪表盘数据 5分钟
REDIS_TTL_BASEDATA=600       # 基础数据 10分钟
REDIS_TTL_SESSION=604800     # 会话 7天
REDIS_TTL_DEFAULT=300        # 默认 5分钟
